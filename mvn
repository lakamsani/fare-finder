#!/bin/bash
# Local mvn shim: delegates Maven lifecycle phases to Gradle.
# Used when Maven is not installed but Gradle is available.
# In CI (GitHub Actions), the real mvn binary is used after downloading dependencies.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

case "$*" in
  *test*)
    exec gradle test "$@" 2>/dev/null || exec /opt/gradle-8.13/bin/gradle test
    ;;
  *compile*)
    exec gradle compileJava
    ;;
  *clean*)
    exec gradle clean
    ;;
  *package*|*install*)
    exec gradle build
    ;;
  *)
    exec gradle "$@"
    ;;
esac
